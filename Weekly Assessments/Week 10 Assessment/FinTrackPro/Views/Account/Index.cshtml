@model List<Account>

<h2>Accounts</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@foreach (var acc in Model)
{
    <div class="card mb-3 p-3">
        <h4>@acc.Name (Balance: @acc.Balance)</h4>

        <table class="table">
            <tr>
                <th>Description</th>
                <th>Amount</th>
                <th>Category</th>
                <th>Date</th>
            </tr>

            @foreach (var t in acc.Transactions)
            {
                <tr>
                    <td>@t.Description</td>
                    <td>@t.Amount</td>
                    <td>@t.Category</td>
                    <td>@t.Date.ToShortDateString()</td>
                </tr>
            }
        </table>
    </div>
}