@model List<Asset>

<h2>Portfolio</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}

@{
    double total = (double)ViewData["Total"];
    double updated = total + 500;
}

<p><b>Total:</b> @total</p>
<p><b>After Bonus:</b> @updated</p>

<table class="table">
    <tr>
        <th>Name</th>
        <th>Value</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Value</td>
            <td>
                <a href="/Asset/Info/@item.Id" class="btn btn-info">Details</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
            </td>
        </tr>
    }
</table>