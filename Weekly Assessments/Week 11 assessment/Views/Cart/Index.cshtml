@model List<TheCentralizedPricingEngine.Models.CartItem>

<div class="container mt-5">
    <h2>🧾 Checkout</h2>

    @if (Model.Count == 0)
    {
        <p>Your cart is empty</p>
    }
    else
    {
        <table class="table">
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Qty</th>
                <th>Total</th>
            </tr>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Product.Name</td>
                    <td>₹ @item.Product.Price</td>
                    <td>@item.Quantity</td>
                    <td>₹ @(item.Product.Price* item.Quantity)</td>
                </tr>
            }
        </table>

        <h4>Total: ₹ @ViewBag.Total</h4>

        <form asp-action="ApplyPromo" method="post">
            <input type="text" name="promoCode" class="form-control mb-2"
                   placeholder="Enter Promo Code" />
            <button class="btn btn-success">Apply Promo</button>
        </form>

        @if (ViewBag.Pricing != null)
        {
            <hr />
            <p>Original: ₹ @ViewBag.Pricing.OriginalPrice</p>
            <p>Discount: ₹ @ViewBag.Pricing.DiscountAmount</p>
            <h3>Final: ₹ @ViewBag.Pricing.FinalPrice</h3>
        }
    }
</div>