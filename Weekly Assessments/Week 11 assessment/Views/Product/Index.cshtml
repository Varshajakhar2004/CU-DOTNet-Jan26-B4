@model List<TheCentralizedPricingEngine.Models.Product>

<div class="container mt-5">
    <h2>🛍️ Product</h2>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card p-3 shadow">
                    <h4>@item.Name</h4>
                    <p>₹ @item.Price</p>

                    <a asp-action="AddToCart"
                           asp-route-id="@item.Id"
                           class="btn btn-primary">
                        Add to Cart
                    </a>
                </div>
            </div>
        }
    </div>
</div>