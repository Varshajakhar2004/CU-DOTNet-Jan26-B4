@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="login-page d-flex align-items-center justify-content-center">
    <div class="card login-card shadow-lg rounded overflow-hidden" style="max-width:900px; width:100%;">
        <div class="row g-0">
            <div class="col-md-5 login-left d-flex flex-column justify-content-center text-white p-4">
                <div class="px-3">
                    <h2 class="fw-bold">Welcome back</h2>
                    <p class="lead">Sign in to access your dashboard and manage your portfolio.</p>
                    <p class="small">Need an account? <a asp-page="./Register" class="text-white fw-bold">Create one</a></p>
                </div>
            </div>
            <div class="col-md-7 p-4">
                <div class="card-body">
                    <h3 class="mb-3">@ViewData["Title"]</h3>
                    <form id="account" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-2" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Password" />
                            <label asp-for="Input.Password">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label" asp-for="Input.RememberMe">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
                            </div>
                            <div>
                                <a id="forgot-password" asp-page="./ForgotPassword">Forgot?</a>
                            </div>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-lg mb-3">Sign in</button>

                        <div class="text-center mb-3 text-muted">or continue with</div>

                        <div class="d-flex gap-2 mb-3">
                            @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                            {
                                <button class="btn btn-outline-secondary w-100" disabled>External providers not configured</button>
                            }
                            else
                            {
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <form class="w-100" method="post" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl">
                                        <button type="submit" name="provider" value="@provider.Name" class="btn btn-outline-primary w-100">Log in with @provider.DisplayName</button>
                                    </form>
                                }
                            }
                        </div>

                        <div class="text-center">
                            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
