@{
    ViewData["Title"] = "Tools";
}

<div class="container mt-4">

    <h2>Our Tools</h2>

    <p>
        We provide useful tools that help developers and businesses
        improve productivity, automate tasks, and manage projects efficiently.
    </p>

    <table class="table table-bordered table-striped mt-4">

        <thead class="table-dark">
            <tr>
                <th>Tool Name</th>
                <th>Purpose</th>
                <th>Status</th>
            </tr>
        </thead>

        <tbody>

            <tr>
                <td>Code Analyzer</td>
                <td>Helps developers detect errors and improve code quality.</td>
                <td><span class="badge bg-success">Available</span></td>
            </tr>

            <tr>
                <td>Project Tracker</td>
                <td>Tool for tracking project progress and team tasks.</td>
                <td><span class="badge bg-success">Available</span></td>
            </tr>

            <tr>
                <td>Database Manager</td>
                <td>Helps manage and monitor databases easily.</td>
                <td><span class="badge bg-warning">Coming Soon</span></td>
            </tr>

            <tr>
                <td>Performance Monitor</td>
                <td>Tracks application performance and system usage.</td>
                <td><span class="badge bg-info">Beta</span></td>
            </tr>

        </tbody>

    </table>

</div>