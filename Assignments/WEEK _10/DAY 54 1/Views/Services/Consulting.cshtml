
@{
    ViewData["Title"] = "Consulting";
}
<div class="container mt-4">

    <h2>Consulting Services</h2>

    <p>
        Our consulting services help organizations improve performance,
        implement modern technologies, and solve complex business problems.
    </p>

    <div class="row mt-4">

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5>IT Strategy</h5>
                    <p>
                        We help businesses plan technology strategies that support
                        growth, innovation, and long-term success.
                    </p>
                    <img src="~/images/download (1).jpg" class="card-img-top" alt="IT Strategy">

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5>Software Solutions</h5>
                    <p>
                        Our experts design and implement custom software
                        solutions tailored to your business needs.
                    </p>
                    <img src="~/images/Software.jpg" class="card-img-top" alt="Software Solutions">
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5>Digital Transformation</h5>
                    <p>
                        We guide organizations in adopting modern digital tools
                        to improve productivity and efficiency.
                    </p>
                    <img src="~/images/digital.jpg" class="card-img-top" alt="Digital Transformations">

                </div>
            </div>
        </div>

    </div>

</div>

