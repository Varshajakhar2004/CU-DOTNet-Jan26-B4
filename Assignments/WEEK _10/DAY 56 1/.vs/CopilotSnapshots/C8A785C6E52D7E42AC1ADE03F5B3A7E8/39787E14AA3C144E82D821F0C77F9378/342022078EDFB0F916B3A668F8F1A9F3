@model QuickLoan.Models.Loan

@{
    ViewData["Title"] = "Delete Loan";
}

<h2>Delete Loan</h2>

<div class="alert alert-warning">
    <strong>Are you sure you want to delete this loan?</strong>
</div>

<div>
    <h4>Loan Details</h4>
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Borrower</dt>
        <dd class="col-sm-10">@Model.BorrowerName</dd>

        <dt class="col-sm-2">Lender</dt>
        <dd class="col-sm-10">@Model.LenderName</dd>

        <dt class="col-sm-2">Amount</dt>
        <dd class="col-sm-10">@Model.Amount</dd>

        <dt class="col-sm-2">Settled</dt>
        <dd class="col-sm-10">@(Model.IsSettled ? "Yes" : "No")</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
